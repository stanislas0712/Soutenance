{% extends "admin/base_site.html" %}
{% load i18n static %}

{% block extrastyle %}
{{ block.super }}
<style>
  /* ── Variables ─────────────────────────────── */
  :root {
    --primary:   #1a56db;
    --success:   #057a55;
    --warning:   #c27803;
    --danger:    #c81e1e;
    --light-bg:  #f3f4f6;
    --card-bg:   #ffffff;
    --border:    #e5e7eb;
    --text:      #111827;
    --muted:     #6b7280;
    --radius:    12px;
  }

  body,
  .content-wrapper,
  .content-wrapper > .content,
  #content-main,
  .wrapper { background: var(--light-bg) !important; }

  /* ── Hero Banner ───────────────────────────── */
  .dash-hero {
    background: linear-gradient(135deg, #1e3a5f 0%, #1a56db 60%, #2563eb 100%);
    color: #fff;
    padding: 48px 40px 40px;
    border-radius: var(--radius);
    margin-bottom: 32px;
    position: relative;
    overflow: hidden;
  }
  .dash-hero::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 260px; height: 260px;
    background: rgba(255,255,255,.07);
    border-radius: 50%;
  }
  .dash-hero::after {
    content: '';
    position: absolute;
    bottom: -80px; right: 80px;
    width: 180px; height: 180px;
    background: rgba(255,255,255,.05);
    border-radius: 50%;
  }
  .dash-hero h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -.5px;
  }
  .dash-hero p {
    font-size: 1rem;
    opacity: .85;
    max-width: 600px;
    margin-bottom: 0;
  }
  .dash-hero .badge-role {
    display: inline-block;
    background: rgba(255,255,255,.2);
    border: 1px solid rgba(255,255,255,.3);
    color: #fff;
    font-size: .78rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* ── Section title ─────────────────────────── */
  .section-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .section-title i { color: var(--primary); }

  /* ── Stat Cards ────────────────────────────── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 32px;
  }
  .stat-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: box-shadow .2s, transform .2s;
    text-decoration: none !important;
    color: var(--text) !important;
  }
  .stat-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,.1);
    transform: translateY(-2px);
  }
  .stat-icon {
    width: 52px; height: 52px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
    flex-shrink: 0;
  }
  .stat-icon.blue   { background: #eff6ff; color: var(--primary); }
  .stat-icon.green  { background: #f0fdf4; color: var(--success); }
  .stat-icon.yellow { background: #fffbeb; color: var(--warning); }
  .stat-icon.red    { background: #fef2f2; color: var(--danger); }
  .stat-icon.purple { background: #f5f3ff; color: #7c3aed; }

  .stat-info .stat-value {
    font-size: 1.9rem;
    font-weight: 800;
    line-height: 1;
    color: var(--text);
  }
  .stat-info .stat-label {
    font-size: .8rem;
    color: var(--muted);
    margin-top: 4px;
    font-weight: 500;
  }

  /* ── Info Cards (2 colonnes) ───────────────── */
  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 32px;
  }
  @media (max-width: 900px) { .info-grid { grid-template-columns: 1fr; } }

  .info-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
  }

  /* ── Quick actions ─────────────────────────── */
  .quick-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .action-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 8px;
    text-decoration: none !important;
    font-weight: 600;
    font-size: .9rem;
    transition: background .15s;
  }
  .action-btn.primary { background: #eff6ff; color: var(--primary); }
  .action-btn.primary:hover { background: #dbeafe; }
  .action-btn.success { background: #f0fdf4; color: var(--success); }
  .action-btn.success:hover { background: #dcfce7; }
  .action-btn.warning { background: #fffbeb; color: var(--warning); }
  .action-btn.warning:hover { background: #fef3c7; }
  .action-btn i { width: 20px; text-align: center; font-size: 1rem; }

  /* ── Budget Alerts ─────────────────────────── */
  .alert-list { display: flex; flex-direction: column; gap: 10px; }
  .alert-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    border-radius: 8px;
    font-size: .88rem;
    font-weight: 500;
  }
  .alert-item.depassement { background: #fef2f2; color: var(--danger); }
  .alert-item.critique    { background: #fff7ed; color: #c2410c; }
  .alert-item.alerte      { background: #fffbeb; color: var(--warning); }
  .alert-item.normal      { background: #f0fdf4; color: var(--success); }
  .alert-item i { font-size: 1.1rem; }
  .alert-item .alert-name { flex: 1; }
  .alert-item .alert-pct  { font-weight: 700; font-size: 1rem; }

  /* ── Dernières transactions ────────────────── */
  .tx-list { display: flex; flex-direction: column; gap: 8px; }
  .tx-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 8px;
    background: var(--light-bg);
    font-size: .87rem;
  }
  .tx-type {
    width: 32px; height: 32px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: .85rem;
    flex-shrink: 0;
  }
  .tx-type.dep { background: #fef2f2; color: var(--danger); }
  .tx-type.rec { background: #f0fdf4; color: var(--success); }
  .tx-info { flex: 1; }
  .tx-libelle { font-weight: 600; color: var(--text); }
  .tx-meta    { color: var(--muted); font-size: .78rem; }
  .tx-montant { font-weight: 700; font-size: .95rem; }
  .tx-montant.dep { color: var(--danger); }
  .tx-montant.rec { color: var(--success); }

  /* ── Pill statuts ──────────────────────────── */
  .pill {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: .73rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .5px;
  }
  .pill.brouillon     { background: #e5e7eb; color: #374151; }
  .pill.en_validation { background: #eff6ff; color: var(--primary); }
  .pill.approuve      { background: #f0fdf4; color: var(--success); }
  .pill.rejete        { background: #fef2f2; color: var(--danger); }
  .pill.actif         { background: #f0fdf4; color: var(--success); }
  .pill.cloture       { background: #e5e7eb; color: #374151; }

  /* ── Empty state ───────────────────────────── */
  .empty-state {
    text-align: center;
    padding: 32px 16px;
    color: var(--muted);
    font-size: .9rem;
  }
  .empty-state i { font-size: 2.5rem; margin-bottom: 8px; display: block; opacity: .4; }
</style>
{% endblock %}

{% block breadcrumbs %}{% endblock %}
{% block content_title %}{% endblock %}

{% block content %}
<div class="col-12" style="padding: 8px 0;">

  {# ── Hero ────────────────────────────────────────── #}
  <div class="dash-hero">
    <span class="badge-role">
      <i class="fas fa-shield-alt"></i>&nbsp;
      {{ request.user.get_role_display|default:"Administration" }}
    </span>
    <h1>Bonjour, {{ request.user.matricule|default:request.user.email }} 👋</h1>
    <p>
      Bienvenue sur la plateforme de <strong>Gestion Budgétaire</strong>.
      Pilotez vos budgets, suivez vos dépenses et validez les transactions en toute simplicité.
    </p>
  </div>

  {# ── KPI Cards ───────────────────────────────────── #}
  <div class="section-title">
    <i class="fas fa-chart-bar"></i> Vue d'ensemble
  </div>
  <div class="stats-grid">
    <a href="{% url 'admin:budget_budget_changelist' %}" class="stat-card">
      <div class="stat-icon blue"><i class="fas fa-wallet"></i></div>
      <div class="stat-info">
        <div class="stat-value">{{ stats.nb_budgets }}</div>
        <div class="stat-label">Budgets total</div>
      </div>
    </a>
    <a href="{% url 'admin:budget_budget_changelist' %}?statut__exact=EN_VALIDATION" class="stat-card">
      <div class="stat-icon yellow"><i class="fas fa-hourglass-half"></i></div>
      <div class="stat-info">
        <div class="stat-value">{{ stats.budgets_en_validation }}</div>
        <div class="stat-label">En validation</div>
      </div>
    </a>
    <a href="{% url 'admin:budget_transaction_changelist' %}" class="stat-card">
      <div class="stat-icon purple"><i class="fas fa-exchange-alt"></i></div>
      <div class="stat-info">
        <div class="stat-value">{{ stats.nb_transactions }}</div>
        <div class="stat-label">Transactions</div>
      </div>
    </a>
    <a href="{% url 'admin:accounts_utilisateur_changelist' %}" class="stat-card">
      <div class="stat-icon green"><i class="fas fa-users"></i></div>
      <div class="stat-info">
        <div class="stat-value">{{ stats.nb_utilisateurs }}</div>
        <div class="stat-label">Utilisateurs</div>
      </div>
    </a>
    <a href="{% url 'admin:accounts_departement_changelist' %}" class="stat-card">
      <div class="stat-icon red"><i class="fas fa-building"></i></div>
      <div class="stat-info">
        <div class="stat-value">{{ stats.nb_departements }}</div>
        <div class="stat-label">Départements</div>
      </div>
    </a>
  </div>

  {# ── Info Grid ───────────────────────────────────── #}
  <div class="info-grid">

    {# Actions rapides #}
    <div class="info-card">
      <div class="section-title"><i class="fas fa-bolt"></i> Actions rapides</div>
      <div class="quick-actions">
        <a href="{% url 'admin:budget_budget_add' %}" class="action-btn primary">
          <i class="fas fa-plus-circle"></i> Créer un budget
        </a>
        <a href="{% url 'admin:budget_transaction_add' %}" class="action-btn success">
          <i class="fas fa-receipt"></i> Nouvelle transaction
        </a>
        <a href="{% url 'admin:accounts_utilisateur_add' %}" class="action-btn warning">
          <i class="fas fa-user-plus"></i> Ajouter un utilisateur
        </a>
        <a href="{% url 'admin:budget_categorie_add' %}" class="action-btn primary">
          <i class="fas fa-tag"></i> Ajouter une catégorie
        </a>
        <a href="{% url 'admin:budget_periode_add' %}" class="action-btn success">
          <i class="fas fa-calendar-plus"></i> Créer une période
        </a>
        <a href="{% url 'admin:audit_logaudit_changelist' %}" class="action-btn warning">
          <i class="fas fa-history"></i> Consulter les logs d'audit
        </a>
      </div>
    </div>

    {# Alertes budgets #}
    <div class="info-card">
      <div class="section-title"><i class="fas fa-bell"></i> Alertes budgétaires</div>
      {% if alertes %}
        <div class="alert-list">
          {% for b in alertes %}
            <a href="{% url 'admin:budget_budget_change' b.id %}" class="alert-item {{ b.niveau_alerte|lower }} text-decoration-none">
              <i class="fas {% if b.niveau_alerte == 'DEPASSEMENT' %}fa-times-circle{% elif b.niveau_alerte == 'CRITIQUE' %}fa-exclamation-circle{% elif b.niveau_alerte == 'ALERTE' %}fa-exclamation-triangle{% else %}fa-check-circle{% endif %}"></i>
              <span class="alert-name">{{ b.nom|truncatechars:30 }}</span>
              <span class="alert-pct">{{ b.calculer_taux_consommation|floatformat:0 }}%</span>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state">
          <i class="fas fa-check-double"></i>
          Aucune alerte budgétaire active
        </div>
      {% endif %}
    </div>

    {# Dernières transactions #}
    <div class="info-card">
      <div class="section-title"><i class="fas fa-clock"></i> Dernières transactions</div>
      {% if dernieres_transactions %}
        <div class="tx-list">
          {% for tx in dernieres_transactions %}
            <a href="{% url 'admin:budget_transaction_change' tx.id %}" class="tx-item text-decoration-none">
              <div class="tx-type {% if tx.type == 'DEPENSE' %}dep{% else %}rec{% endif %}">
                <i class="fas {% if tx.type == 'DEPENSE' %}fa-arrow-up{% else %}fa-arrow-down{% endif %}"></i>
              </div>
              <div class="tx-info">
                <div class="tx-libelle">{{ tx.libelle|truncatechars:28 }}</div>
                <div class="tx-meta">{{ tx.date_transaction|date:"d/m/Y" }} — {{ tx.budget.code }}</div>
              </div>
              <div class="tx-montant {% if tx.type == 'DEPENSE' %}dep{% else %}rec{% endif %}">
                {% if tx.type == 'DEPENSE' %}-{% else %}+{% endif %}{{ tx.montant|floatformat:0 }} F
              </div>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state">
          <i class="fas fa-receipt"></i>
          Aucune transaction enregistrée
        </div>
      {% endif %}
    </div>

    {# Budgets récents #}
    <div class="info-card">
      <div class="section-title"><i class="fas fa-folder-open"></i> Budgets récents</div>
      {% if budgets_recents %}
        <div class="tx-list">
          {% for b in budgets_recents %}
            <a href="{% url 'admin:budget_budget_change' b.id %}" class="tx-item text-decoration-none">
              <div class="tx-type rec">
                <i class="fas fa-wallet"></i>
              </div>
              <div class="tx-info">
                <div class="tx-libelle">{{ b.nom|truncatechars:28 }}</div>
                <div class="tx-meta">{{ b.departement.nom }} — {{ b.periode.nom }}</div>
              </div>
              <span class="pill {{ b.statut|lower }}">{{ b.get_statut_display }}</span>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state">
          <i class="fas fa-wallet"></i>
          Aucun budget créé
        </div>
      {% endif %}
    </div>

  </div>{# /info-grid #}

</div>
{% endblock %}
