# ─────────────────────────────────────────────────────────────────────────────
# BudgetFlow — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# NE JAMAIS committer .env dans git !
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-use-python-to-generate-a-real-secret-key-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ── Base de données PostgreSQL ────────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=budgetflow
DB_USER=budgetflow
DB_PASSWORD=change-me-db-password
DB_HOST=postgres
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── MinIO / AWS S3 ────────────────────────────────────────────────────────────
USE_S3=True
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=budgetflow
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1


# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Nombre de tentatives avant verrouillage du compte
MAX_LOGIN_ATTEMPTS=5
# Durée de verrouillage en minutes
ACCOUNT_LOCK_DURATION_MINUTES=30

# ── Sentry (laisser vide en dev) ──────────────────────────────────────────────
SENTRY_DSN=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ── Intelligence Artificielle — Claude (Anthropic) ────────────────────────────
# Obtenir sur: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-votre-cle-ici
# Mettre True pour désactiver les appels Claude (dev sans API key)
SKIP_CLAUDE_API=False


EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-smtp-user@example.com
EMAIL_HOST_PASSWORD=change-me-email-app-password
DEFAULT_FROM_EMAIL=BudgetFlow <noreply@example.com>
FRONTEND_URL=http://localhost:5173